#!/bin/bash
# Core logic: on a Renovate Docker-digest diff, scan every bumped image with Syft
# and post its package-level SBOM diff into the PR description. When an image's
# Node.js runtime version changed, also post the Node.js changelogs in between.
set -euo pipefail

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/shared.bash
source "${HOOK_DIR}/../lib/shared.bash"

MAX_RELEASES=20
MARKER_START="<!-- docker-node-diff:start -->"
MARKER_END="<!-- docker-node-diff:end -->"
DIST_INDEX_URL="https://nodejs.org/dist/index.json"
CHANGELOG_URL_BASE="https://raw.githubusercontent.com/nodejs/node/main/doc/changelogs"

WORKDIR="$(mktemp -d)"
trap 'rm -rf "${WORKDIR}"' EXIT

log() { echo "docker-node-diff: $*" >&2; }

# Scans an image with Syft into a normalized "type<TAB>name<TAB>version" list,
# one package per line, sorted. Leaves an empty file if the scan fails.
scan_packages() {
  local ref="$1" out="$2"
  if ! syft scan "registry:${ref}" -q -o syft-json 2>/dev/null \
       | jq -r '.artifacts[] | [.type, .name, .version] | @tsv' \
       | sort -u >"$out"; then
    : >"$out"
  fi
}

# Reads the Node.js runtime version from a scan file, preferring the binary
# artifact (the real runtime) over a generic "node" package entry.
node_version_from() {
  awk -F'\t' '
    $2 == "node" { if ($1 == "binary") b = $3; else if (g == "") g = $3 }
    END { print (b != "" ? b : g) }
  ' "$1"
}

# Markdown bullets describing how the package set changed from $1 (old scan) to
# $2 (new scan): one line per added, removed, or version-changed package, sorted
# by name. Packages are keyed by type+name so a version move is a single bump
# rather than an add/remove pair.
diff_packages() {
  awk -F'\t' '
    # Registry/distro page for a package, or "" when we have no good target.
    # node is matched by name (its artifact type is "binary") before the
    # type-based cases so the runtime still gets a link.
    function pkg_url(type, name, ver) {
      if (name == "node")  return "https://nodejs.org/en/blog/release/v" ver
      if (type == "npm")   return "https://www.npmjs.com/package/" name "/v/" ver
      if (type == "deb")   return "https://packages.debian.org/" name
      if (type == "apk")   return "https://pkgs.alpinelinux.org/packages?name=" name
      return ""
    }
    # Package name as clickable inline code, or plain inline code when unlinked.
    function lnk(type, name, ver,   u) {
      u = pkg_url(type, name, ver)
      return u == "" ? "`" name "`" : "[`" name "`](" u ")"
    }
    FNR == NR { ov[$1 FS $2] = $3; onm[$1 FS $2] = $2; otype[$1 FS $2] = $1; next }
    {
      k = $1 FS $2; seen[k] = 1
      if (!(k in ov))       printf "%s\t- %s added (`%s`)\n", $2, lnk($1, $2, $3), $3
      else if (ov[k] != $3) printf "%s\t- %s: `%s` → `%s`\n", $2, lnk($1, $2, $3), ov[k], $3
    }
    END {
      for (k in ov) if (!(k in seen))
        printf "%s\t- %s removed (`%s`)\n", onm[k], lnk(otype[k], onm[k], ov[k]), ov[k]
    }
  ' "$1" "$2" | sort -f | cut -f2-
}

fetch_dist_index() {
  if [ ! -f "${WORKDIR}/index.json" ]; then
    curl --proto '=https' --tlsv1.2 -fsSL "${DIST_INDEX_URL}" \
      -o "${WORKDIR}/index.json" 2>/dev/null || return 1
  fi
}

# Releases in the half-open range (before, after], newest first, capped at MAX_RELEASES.
releases_between() {
  local before="$1"
  local after="$2"
  fetch_dist_index || return 0

  local out=()
  local v
  while IFS= read -r v; do
    [ -z "$v" ] && continue
    if version_gt "$v" "$before" && { [ "$v" = "$after" ] || version_gt "$after" "$v"; }; then
      out+=("$v")
    fi
  done < <(jq -r '.[].version' "${WORKDIR}/index.json" | sed 's/^v//')

  [ ${#out[@]} -eq 0 ] && return 0
  printf '%s\n' "${out[@]}" | sort -rV | head -n "${MAX_RELEASES}"
}

# Pulls one release's section out of its major-version changelog, or links to the
# GitHub release tag when the section can't be found.
changelog_section() {
  local version="$1"
  local major="${version%%.*}"
  local file="${WORKDIR}/CHANGELOG_V${major}.md"

  if [ ! -f "$file" ]; then
    curl --proto '=https' --tlsv1.2 -fsSL "${CHANGELOG_URL_BASE}/CHANGELOG_V${major}.md" \
      -o "$file" 2>/dev/null || : >"$file"
  fi

  awk -v id="$version" '
    BEGIN { tag = "<a id=\"" id "\"" }
    index($0, tag) { cap = 1; found = 1; print; next }
    cap && index($0, "<a id=\"") { cap = 0 }
    cap { print }
    END { if (!found) printf "See https://github.com/nodejs/node/releases/tag/v%s", id }
  ' "$file"
}

# Pairs each removed ref with an added ref by repo:tag first, then by repo, so a
# digest bump still matches even when the tag changed in the same update.
pair_digests() {
  local n_removed=${#removed_refs[@]}
  local n_added=${#added_refs[@]}
  local rtaken=() ataken=()
  local i j pass key_r key_a

  for ((i = 0; i < n_removed; i++)); do rtaken[i]=0; done
  for ((j = 0; j < n_added; j++)); do ataken[j]=0; done
  pairs_before=()
  pairs_after=()

  for pass in 1 2; do
    for ((i = 0; i < n_removed; i++)); do
      [ "${rtaken[$i]}" = 1 ] && continue
      if [ "$pass" = 1 ]; then
        key_r="$(image_repo_tag "${removed_refs[$i]}")"
      else
        key_r="$(image_repo "${removed_refs[$i]}")"
      fi
      for ((j = 0; j < n_added; j++)); do
        [ "${ataken[$j]}" = 1 ] && continue
        if [ "$pass" = 1 ]; then
          key_a="$(image_repo_tag "${added_refs[$j]}")"
        else
          key_a="$(image_repo "${added_refs[$j]}")"
        fi
        if [ "$key_r" = "$key_a" ]; then
          pairs_before+=("${removed_refs[$i]}")
          pairs_after+=("${added_refs[$j]}")
          rtaken[i]=1
          ataken[j]=1
          break
        fi
      done
    done
  done
}

upsert_pr() {
  local blockfile="$1"
  local have_content="$2"

  if ! command -v gh >/dev/null 2>&1; then
    log "gh not on PATH; skipping PR update"
    return 0
  fi

  local token_env token
  token_env="$(plugin_read GITHUB_TOKEN_ENV "GITHUB_TOKEN")"
  token="${!token_env:-}"
  if [ -z "$token" ]; then
    log "token env ${token_env} is empty; skipping PR update"
    return 0
  fi

  local repo_url slug
  repo_url="${BUILDKITE_PULL_REQUEST_REPO:-${BUILDKITE_REPO:-}}"
  slug="$(repo_slug "$repo_url")"

  local pr="${BUILDKITE_PULL_REQUEST:-}"
  case "$pr" in
    '' | *[!0-9]*)
      # Buildkite only sets BUILDKITE_PULL_REQUEST to a number on PR-triggered
      # builds; for branch-push builds it is "false". Fall back to looking up an
      # open PR (including drafts) for the current branch.
      local branch="${BUILDKITE_BRANCH:-}"
      if [ -z "$branch" ]; then
        log "not a pull request and no branch to resolve; skipping PR update"
        return 0
      fi
      pr="$(GH_TOKEN="$token" gh pr list --repo "$slug" --head "$branch" \
            --state open --json number -q '.[0].number' 2>/dev/null)"
      case "$pr" in
        '' | *[!0-9]*)
          log "no open PR for branch ${branch}; skipping PR update"
          return 0
          ;;
      esac
      log "resolved open PR #${pr} for branch ${branch}"
      ;;
  esac

  local cur
  if ! cur="$(GH_TOKEN="$token" gh pr view "$pr" --repo "$slug" --json body -q .body 2>/dev/null)"; then
    log "could not read PR #${pr} body; skipping PR update"
    return 0
  fi
  [ "$cur" = "null" ] && cur=""

  local newbody="${WORKDIR}/newbody.md"
  if grep -qF "$MARKER_START" <<<"$cur"; then
    awk -v start="$MARKER_START" -v end="$MARKER_END" -v bf="$blockfile" '
      function dumpblock() { while ((getline l < bf) > 0) print l; close(bf) }
      index($0, start) { dumpblock(); skip = 1; next }
      index($0, end)   { skip = 0; next }
      !skip            { print }
    ' <<<"$cur" >"$newbody"
  elif [ "$have_content" -gt 0 ]; then
    { printf '%s\n\n---\n\n' "$cur"; cat "$blockfile"; } >"$newbody"
  else
    log "no image changes and no existing block; leaving PR description untouched"
    return 0
  fi

  if ! GH_TOKEN="$token" gh pr edit "$pr" --repo "$slug" --body-file "$newbody"; then
    log "could not update PR #${pr}"
    return 0
  fi
  log "updated PR #${pr} description"
}

main() {
  # Only run on the configured Renovate branch(es); other branches won't carry
  # the digest bumps this plugin looks for.
  local branch="${BUILDKITE_BRANCH:-}"
  if [ -z "$branch" ]; then
    branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  fi

  local result
  if ! read_list_property BRANCHES; then
    result=("renovate-docker-images")
  fi
  local allowed=0 b
  for b in "${result[@]}"; do
    if [ "$b" = "$branch" ]; then allowed=1; break; fi
  done
  if [ "$allowed" -ne 1 ]; then
    log "branch '${branch}' not in allow-list; skipping"
    exit 0
  fi

  # Refuse fork PRs: the diff (and thus the images we pull and the versions we
  # render) is attacker-controlled when the PR source repo isn't the base repo.
  # The branch allow-list alone is not a trust boundary -- a fork can name its
  # branch anything. Only PR builds are gated; non-PR (push) builds on the
  # renovate branch are the trusted internal case.
  local pr="${BUILDKITE_PULL_REQUEST:-}"
  case "$pr" in
    '' | *[!0-9]*) ;; # not a PR build -> trusted internal build, no fork risk
    *)
      local src_repo="${BUILDKITE_PULL_REQUEST_REPO:-}"
      local base_repo="${BUILDKITE_REPO:-}"
      if [ -n "$src_repo" ] && [ -n "$base_repo" ] \
         && [ "$(repo_slug "$src_repo")" != "$(repo_slug "$base_repo")" ]; then
        log "pull request from a fork (source repo != base repo); refusing to scan untrusted images; skipping"
        exit 0
      fi
      ;;
  esac

  # Diff against origin/<base>, falling back to a local <base>, then HEAD~1.
  local base="${BUILDKITE_PIPELINE_DEFAULT_BRANCH:-main}"
  local diff_base
  if git rev-parse --verify -q "origin/${base}" >/dev/null; then
    diff_base="origin/${base}"
  elif git rev-parse --verify -q "${base}" >/dev/null; then
    diff_base="${base}"
  else
    diff_base="HEAD~1"
  fi

  local diff
  diff="$(git --no-pager diff "${diff_base}...HEAD" || true)"

  # Collect @sha256 image refs from removed (-) and added (+) diff lines.
  local regex='[A-Za-z0-9][A-Za-z0-9._/:-]*@sha256:[0-9a-fA-F]{64}'
  removed_refs=()
  added_refs=()
  local line
  while IFS= read -r line; do
    [ -n "$line" ] && removed_refs+=("$line")
  done < <(printf '%s\n' "$diff" | grep '^-' | grep -oE "$regex" || true)
  while IFS= read -r line; do
    [ -n "$line" ] && added_refs+=("$line")
  done < <(printf '%s\n' "$diff" | grep '^+' | grep -oE "$regex" || true)

  pair_digests

  local report="${WORKDIR}/report.md"
  : >"$report"
  local nchanged_img=0 nnode=0
  local npairs=${#pairs_before[@]}
  local p bref aref bver aver v sec
  local seen=()
  for ((p = 0; p < npairs; p++)); do
    bref="${pairs_before[$p]}"
    aref="${pairs_after[$p]}"

    # Skip duplicate before->after pairs (e.g. one image pinned via several
    # compose anchors) so each digest bump is scanned and reported once.
    local sig="${bref}=>${aref}" s dup=0
    for s in "${seen[@]}"; do [ "$s" = "$sig" ] && { dup=1; break; }; done
    [ "$dup" = 1 ] && continue
    seen+=("$sig")

    local repo bshort ashort
    repo="$(image_repo "$aref")"
    bshort="$(short_digest "$bref")"
    ashort="$(short_digest "$aref")"
    log "checking ${repo} (${bshort} -> ${ashort})"

    local oldpkgs="${WORKDIR}/old.${p}.tsv" newpkgs="${WORKDIR}/new.${p}.tsv"
    scan_packages "$bref" "$oldpkgs"
    scan_packages "$aref" "$newpkgs"

    bver="$(node_version_from "$oldpkgs")"
    aver="$(node_version_from "$newpkgs")"

    local node_changed=0
    if [ -n "$bver" ] && [ -n "$aver" ] \
       && is_node_version "$bver" && is_node_version "$aver" \
       && [ "$bver" != "$aver" ]; then
      node_changed=1
    fi

    local pkgdiff
    pkgdiff="$(diff_packages "$oldpkgs" "$newpkgs")"

    nchanged_img=$((nchanged_img + 1))

    # Every bumped image gets a section with its package diff; the Node.js
    # version line and changelogs are added only when the runtime moved.
    {
      # shellcheck disable=SC2016 # backticks are literal markdown, not command substitution
      printf '### %s (`%s` → `%s`)\n\n' "$repo" "$bshort" "$ashort"
    } >>"$report"

    if [ "$node_changed" = 1 ]; then
      # shellcheck disable=SC2016
      printf 'Node.js `%s` → `%s`\n\n' "$bver" "$aver" >>"$report"
    fi

    if [ -n "$pkgdiff" ]; then
      local ndiff
      ndiff="$(printf '%s\n' "$pkgdiff" | wc -l | tr -d ' ')"
      {
        printf '<details><summary>%s package change(s)</summary>\n\n' "$ndiff"
        printf '%s\n\n' "$pkgdiff"
        printf '</details>\n\n'
      } >>"$report"
    else
      printf '_No package changes detected._\n\n' >>"$report"
    fi

    if [ "$node_changed" = 1 ]; then
      nnode=$((nnode + 1))
      local releases
      releases="$(releases_between "$bver" "$aver")"
      if [ -n "$releases" ]; then
        printf '#### Node.js changelog\n\n' >>"$report"
        while IFS= read -r v; do
          [ -z "$v" ] && continue
          sec="$(changelog_section "$v")"
          printf '<details><summary>v%s</summary>\n\n%s\n\n</details>\n\n' "$v" "$sec" >>"$report"
        done <<<"$releases"
      else
        log "no in-range Node.js releases for ${bver} -> ${aver}"
      fi
    fi
  done

  local final="${WORKDIR}/final.md"
  {
    printf '## Docker image changes\n\n'
    if [ "$nchanged_img" -gt 0 ]; then
      if [ "$nnode" -gt 0 ]; then
        printf '%s Docker image(s) changed; %s bumped the Node.js runtime.\n\n' "$nchanged_img" "$nnode"
      else
        printf '%s Docker image(s) changed; no Node.js runtime change.\n\n' "$nchanged_img"
      fi
      cat "$report"
    else
      printf '_No Docker image changes detected in this update._\n'
    fi
  } >"$final"

  local block="${WORKDIR}/block.md"
  {
    printf '%s\n\n' "$MARKER_START"
    cat "$final"
    printf '\n%s\n' "$MARKER_END"
  } >"$block"

  cat "$final"
  upsert_pr "$block" "$nchanged_img"
}

main "$@"
