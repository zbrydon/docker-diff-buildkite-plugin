#!/bin/bash
# Core logic: detect Node.js runtime version bumps from a Renovate Docker-digest
# diff and post the Node.js changelogs in between into the PR description.
set -euo pipefail

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/shared.bash
source "${HOOK_DIR}/../lib/shared.bash"

MAX_RELEASES=20
MARKER_START="<!-- docker-node-diff:start -->"
MARKER_END="<!-- docker-node-diff:end -->"
DIST_INDEX_URL="https://nodejs.org/dist/index.json"
CHANGELOG_URL_BASE="https://raw.githubusercontent.com/nodejs/node/main/doc/changelogs"

WORKDIR="$(mktemp -d)"
trap 'rm -rf "${WORKDIR}"' EXIT

log() { echo "docker-node-diff: $*" >&2; }

# Scans the image with Syft and prefers the binary artifact's version over a
# generic "node" package entry, since only the former reflects the real runtime.
read_node_version() {
  local ref="$1"
  syft scan "registry:${ref}" -q -o syft-json 2>/dev/null \
    | jq -r '[.artifacts[] | select(.name == "node")] as $n
             | (($n | map(select(.type == "binary")) | .[0].version)
                // ($n | .[0].version) // empty)'
}

fetch_dist_index() {
  if [ ! -f "${WORKDIR}/index.json" ]; then
    curl --proto '=https' --tlsv1.2 -fsSL "${DIST_INDEX_URL}" \
      -o "${WORKDIR}/index.json" 2>/dev/null || return 1
  fi
}

# Releases in the half-open range (before, after], newest first, capped at MAX_RELEASES.
releases_between() {
  local before="$1"
  local after="$2"
  fetch_dist_index || return 0

  local out=()
  local v
  while IFS= read -r v; do
    [ -z "$v" ] && continue
    if version_gt "$v" "$before" && { [ "$v" = "$after" ] || version_gt "$after" "$v"; }; then
      out+=("$v")
    fi
  done < <(jq -r '.[].version' "${WORKDIR}/index.json" | sed 's/^v//')

  [ ${#out[@]} -eq 0 ] && return 0
  printf '%s\n' "${out[@]}" | sort -rV | head -n "${MAX_RELEASES}"
}

# Pulls one release's section out of its major-version changelog, or links to the
# GitHub release tag when the section can't be found.
changelog_section() {
  local version="$1"
  local major="${version%%.*}"
  local file="${WORKDIR}/CHANGELOG_V${major}.md"

  if [ ! -f "$file" ]; then
    curl --proto '=https' --tlsv1.2 -fsSL "${CHANGELOG_URL_BASE}/CHANGELOG_V${major}.md" \
      -o "$file" 2>/dev/null || : >"$file"
  fi

  awk -v id="$version" '
    BEGIN { tag = "<a id=\"" id "\"" }
    index($0, tag) { cap = 1; found = 1; print; next }
    cap && index($0, "<a id=\"") { cap = 0 }
    cap { print }
    END { if (!found) printf "See https://github.com/nodejs/node/releases/tag/v%s", id }
  ' "$file"
}

# Pairs each removed ref with an added ref by repo:tag first, then by repo, so a
# digest bump still matches even when the tag changed in the same update.
pair_digests() {
  local n_removed=${#removed_refs[@]}
  local n_added=${#added_refs[@]}
  local rtaken=() ataken=()
  local i j pass key_r key_a

  for ((i = 0; i < n_removed; i++)); do rtaken[i]=0; done
  for ((j = 0; j < n_added; j++)); do ataken[j]=0; done
  pairs_before=()
  pairs_after=()

  for pass in 1 2; do
    for ((i = 0; i < n_removed; i++)); do
      [ "${rtaken[$i]}" = 1 ] && continue
      if [ "$pass" = 1 ]; then
        key_r="$(image_repo_tag "${removed_refs[$i]}")"
      else
        key_r="$(image_repo "${removed_refs[$i]}")"
      fi
      for ((j = 0; j < n_added; j++)); do
        [ "${ataken[$j]}" = 1 ] && continue
        if [ "$pass" = 1 ]; then
          key_a="$(image_repo_tag "${added_refs[$j]}")"
        else
          key_a="$(image_repo "${added_refs[$j]}")"
        fi
        if [ "$key_r" = "$key_a" ]; then
          pairs_before+=("${removed_refs[$i]}")
          pairs_after+=("${added_refs[$j]}")
          rtaken[i]=1
          ataken[j]=1
          break
        fi
      done
    done
  done
}

upsert_pr() {
  local blockfile="$1"
  local changed="$2"

  local pr="${BUILDKITE_PULL_REQUEST:-}"
  case "$pr" in
    '' | *[!0-9]*)
      log "not a pull request; skipping PR update"
      return 0
      ;;
  esac

  if ! command -v gh >/dev/null 2>&1; then
    log "gh not on PATH; skipping PR update"
    return 0
  fi

  local token_env token
  token_env="$(plugin_read GITHUB_TOKEN_ENV "GITHUB_TOKEN")"
  token="${!token_env:-}"
  if [ -z "$token" ]; then
    log "token env ${token_env} is empty; skipping PR update"
    return 0
  fi

  local repo_url slug
  repo_url="${BUILDKITE_PULL_REQUEST_REPO:-${BUILDKITE_REPO:-}}"
  slug="$(repo_slug "$repo_url")"

  local cur
  if ! cur="$(GH_TOKEN="$token" gh pr view "$pr" --repo "$slug" --json body -q .body 2>/dev/null)"; then
    log "could not read PR #${pr} body; skipping PR update"
    return 0
  fi
  [ "$cur" = "null" ] && cur=""

  local newbody="${WORKDIR}/newbody.md"
  if grep -qF "$MARKER_START" <<<"$cur"; then
    awk -v start="$MARKER_START" -v end="$MARKER_END" -v bf="$blockfile" '
      function dumpblock() { while ((getline l < bf) > 0) print l; close(bf) }
      index($0, start) { dumpblock(); skip = 1; next }
      index($0, end)   { skip = 0; next }
      !skip            { print }
    ' <<<"$cur" >"$newbody"
  elif [ "$changed" -gt 0 ]; then
    { printf '%s\n\n---\n\n' "$cur"; cat "$blockfile"; } >"$newbody"
  else
    log "no changes and no existing block; leaving PR description untouched"
    return 0
  fi

  if ! GH_TOKEN="$token" gh pr edit "$pr" --repo "$slug" --body-file "$newbody"; then
    log "could not update PR #${pr}"
    return 0
  fi
  log "updated PR #${pr} description"
}

main() {
  # Only run on the configured Renovate branch(es); other branches won't carry
  # the digest bumps this plugin looks for.
  local branch="${BUILDKITE_BRANCH:-}"
  if [ -z "$branch" ]; then
    branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  fi

  local result
  if ! read_list_property BRANCHES; then
    result=("renovate-docker-images")
  fi
  local allowed=0 b
  for b in "${result[@]}"; do
    if [ "$b" = "$branch" ]; then allowed=1; break; fi
  done
  if [ "$allowed" -ne 1 ]; then
    log "branch '${branch}' not in allow-list; skipping"
    exit 0
  fi

  # Refuse fork PRs: the diff (and thus the images we pull and the versions we
  # render) is attacker-controlled when the PR source repo isn't the base repo.
  # The branch allow-list alone is not a trust boundary -- a fork can name its
  # branch anything. Only PR builds are gated; non-PR (push) builds on the
  # renovate branch are the trusted internal case.
  local pr="${BUILDKITE_PULL_REQUEST:-}"
  case "$pr" in
    '' | *[!0-9]*) ;; # not a PR build -> trusted internal build, no fork risk
    *)
      local src_repo="${BUILDKITE_PULL_REQUEST_REPO:-}"
      local base_repo="${BUILDKITE_REPO:-}"
      if [ -n "$src_repo" ] && [ -n "$base_repo" ] \
         && [ "$(repo_slug "$src_repo")" != "$(repo_slug "$base_repo")" ]; then
        log "pull request from a fork (source repo != base repo); refusing to scan untrusted images; skipping"
        exit 0
      fi
      ;;
  esac

  # Diff against origin/<base>, falling back to a local <base>, then HEAD~1.
  local base="${BUILDKITE_PIPELINE_DEFAULT_BRANCH:-main}"
  local diff_base
  if git rev-parse --verify -q "origin/${base}" >/dev/null; then
    diff_base="origin/${base}"
  elif git rev-parse --verify -q "${base}" >/dev/null; then
    diff_base="${base}"
  else
    diff_base="HEAD~1"
  fi

  local diff
  diff="$(git --no-pager diff "${diff_base}...HEAD" || true)"

  # Collect @sha256 image refs from removed (-) and added (+) diff lines.
  local regex='[A-Za-z0-9][A-Za-z0-9._/:-]*@sha256:[0-9a-fA-F]{64}'
  removed_refs=()
  added_refs=()
  local line
  while IFS= read -r line; do
    [ -n "$line" ] && removed_refs+=("$line")
  done < <(printf '%s\n' "$diff" | grep '^-' | grep -oE "$regex" || true)
  while IFS= read -r line; do
    [ -n "$line" ] && added_refs+=("$line")
  done < <(printf '%s\n' "$diff" | grep '^+' | grep -oE "$regex" || true)

  pair_digests

  local report="${WORKDIR}/report.md"
  : >"$report"
  local changed=0
  local npairs=${#pairs_before[@]}
  local p bref aref bver aver v sec
  for ((p = 0; p < npairs; p++)); do
    bref="${pairs_before[$p]}"
    aref="${pairs_after[$p]}"
    log "checking $(image_repo "$aref") ($(short_digest "$bref") -> $(short_digest "$aref"))"

    bver="$(read_node_version "$bref" 2>/dev/null)" || bver=""
    aver="$(read_node_version "$aref" 2>/dev/null)" || aver=""
    if [ -z "$bver" ] || [ -z "$aver" ]; then
      continue
    fi
    if ! is_node_version "$bver" || ! is_node_version "$aver"; then
      log "unexpected version string from scan; skipping"
      continue
    fi
    if [ "$bver" = "$aver" ]; then
      continue
    fi

    local releases
    releases="$(releases_between "$bver" "$aver")"
    if [ -z "$releases" ]; then
      log "no in-range Node.js releases for ${bver} -> ${aver}; skipping"
      continue
    fi

    changed=$((changed + 1))
    {
      # shellcheck disable=SC2016 # backticks are literal markdown, not command substitution
      printf '### %s (`%s` → `%s`)\n\n' \
        "$(image_repo "$aref")" "$(short_digest "$bref")" "$(short_digest "$aref")"
      # shellcheck disable=SC2016
      printf 'Node.js `%s` → `%s`\n\n' "$bver" "$aver"
    } >>"$report"

    while IFS= read -r v; do
      [ -z "$v" ] && continue
      sec="$(changelog_section "$v")"
      printf '<details><summary>v%s</summary>\n\n%s\n\n</details>\n\n' "$v" "$sec" >>"$report"
    done <<<"$releases"
  done

  local final="${WORKDIR}/final.md"
  {
    printf '## Node.js version changes\n\n'
    if [ "$changed" -gt 0 ]; then
      printf '%s Docker image(s) bumped the Node.js runtime in this update.\n\n' "$changed"
      cat "$report"
    else
      printf '_No Node.js runtime version changes detected in this update._\n'
    fi
  } >"$final"

  local block="${WORKDIR}/block.md"
  {
    printf '%s\n\n' "$MARKER_START"
    cat "$final"
    printf '\n%s\n' "$MARKER_END"
  } >"$block"

  cat "$final"
  upsert_pr "$block" "$changed"
}

main "$@"
